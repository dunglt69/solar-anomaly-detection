{
  "name": "energiamind-server",
  "version": "1.0.0",
  "description": "EnergiaMind API Server — Fastify 5 + SQLite + JWT Auth",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:setup": "npm run db:push && npm run db:seed",
    "simulate": "tsx tools/simulator.ts --interval=5000 --no-history",
    "test": "vitest run",
    "test:load": "tsx tools/load-test.ts",
    "test:security": "tsx tools/pentest-scanner.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/under-pressure": "^9.0.3",
    "@fastify/websocket": "^11.2.0",
    "@libsql/client": "^0.17.3",
    "@types/ws": "^8.18.1",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "jose": "^6.2.3",
    "modbus-serial": "^8.0.25",
    "nanoid": "^5.1.11",
    "onnxruntime-node": "^1.26.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
